#!/bin/bash
set -euo pipefail

# Navigate to the project root
cd "$(dirname "$0")/.."

mkdir -p ./Logs
rm -f ./Logs/build_logs.txt

# TRUNCATE LOGS: Wipes the file to 0 bytes so you catch only THIS run's logs
# We use ': >' instead of 'rm' so the grablogs process keeps its file handle
: > ./Logs/test_logs.txt

echo "🧪 Building and Testing InkOS..."

DESTINATION="platform=iOS Simulator,name=iPhone 17 Pro"
DERIVED_DATA_PATH="./Logs/DerivedData"

xcodebuild test \
  -workspace InkOS.xcworkspace \
  -scheme InkOS \
  -destination "$DESTINATION" \
  -derivedDataPath "$DERIVED_DATA_PATH" \
  -allowProvisioningUpdates \
  COMPILER_INDEX_STORE_ENABLE=NO \
  CODE_SIGNING_ALLOWED=NO \
  | xcbeautify --disable-colored-output | tee ./Logs/test_logs.txt