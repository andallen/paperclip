#!/bin/bash
# UI test runner with lock file mechanism.
# Prevents multiple Claude instances from running tests simultaneously.
# Runs UI tests on Andrew's iPad.

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
LOCK_FILE="/tmp/inkos-ui-test.lock"
LOCK_TIMEOUT=300  # 5 min max test duration
LOG_DIR="/tmp/inkos-ui-tests"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)

# Device configuration.
IPAD_NAME="Andrew's iPad"
IPAD_UDID="00008120-001665CC21900032"
BUNDLE_ID="me.andy.allen.Trivial"

# Colors for output.
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Check for stale lock and acquire lock.
acquire_lock() {
    if [ -f "$LOCK_FILE" ]; then
        lock_age=$(($(date +%s) - $(stat -f %m "$LOCK_FILE" 2>/dev/null || echo 0)))
        if [ $lock_age -gt $LOCK_TIMEOUT ]; then
            log_warn "Removing stale lock file (age: ${lock_age}s)"
            rm -f "$LOCK_FILE"
        else
            lock_pid=$(cat "$LOCK_FILE" 2>/dev/null || echo "unknown")
            log_error "Tests already running (lock exists, PID: $lock_pid, age: ${lock_age}s)"
            log_error "Wait for completion or remove $LOCK_FILE if stale"
            exit 1
        fi
    fi

    # Acquire lock.
    echo $$ > "$LOCK_FILE"
    trap "rm -f $LOCK_FILE; log_info 'Lock released'" EXIT
    log_info "Lock acquired (PID: $$)"
}

# Create output directory.
setup_output_dir() {
    mkdir -p "$LOG_DIR"
    RESULT_DIR="$LOG_DIR/$TIMESTAMP"
    mkdir -p "$RESULT_DIR"
    log_info "Results will be saved to: $RESULT_DIR"
}

# Check if device is connected.
check_device() {
    log_info "Checking for connected iPad..."
    if xcrun devicectl list devices 2>/dev/null | grep -q "$IPAD_UDID"; then
        log_info "iPad found: $IPAD_UDID"
        return 0
    else
        log_warn "iPad not connected. Available devices:"
        xcrun devicectl list devices 2>/dev/null || xcrun xctrace list devices
        return 1
    fi
}

# Run UI tests on device.
run_tests() {
    local destination="$1"
    local test_filter="$2"

    log_info "Building and running UI tests..."
    log_info "Destination: $destination"

    cd "$PROJECT_DIR"

    # Build and test command.
    local cmd="xcodebuild test \
        -workspace InkOS.xcworkspace \
        -scheme InkOS \
        -destination \"$destination\" \
        -resultBundlePath \"$RESULT_DIR/TestResults.xcresult\" \
        -derivedDataPath \"$PROJECT_DIR/Logs.nosync/DerivedData\""

    # Add test filter if specified.
    if [ -n "$test_filter" ]; then
        cmd="$cmd -only-testing:InkOSUITests/$test_filter"
    fi

    # Run tests and capture output.
    log_info "Running: $cmd"
    eval $cmd 2>&1 | tee "$RESULT_DIR/test_output.log"

    local exit_code=${PIPESTATUS[0]}

    if [ $exit_code -eq 0 ]; then
        log_info "Tests PASSED"
    else
        log_error "Tests FAILED (exit code: $exit_code)"
    fi

    return $exit_code
}

# Extract screenshots from test results.
extract_screenshots() {
    log_info "Extracting screenshots from test results..."

    if [ -d "$RESULT_DIR/TestResults.xcresult" ]; then
        # Extract attachments using xcresulttool.
        xcrun xcresulttool get --path "$RESULT_DIR/TestResults.xcresult" \
            --format json > "$RESULT_DIR/results.json" 2>/dev/null || true

        # Find and copy screenshot attachments.
        find "$RESULT_DIR/TestResults.xcresult" -name "*.png" -o -name "*.jpg" 2>/dev/null | while read img; do
            cp "$img" "$RESULT_DIR/" 2>/dev/null || true
        done

        log_info "Screenshots saved to: $RESULT_DIR/"
    fi
}

# Fetch app logs from device.
fetch_device_logs() {
    log_info "Fetching app logs from device..."

    # Try to get recent logs using devicectl.
    xcrun devicectl device syslog --device "$IPAD_UDID" 2>/dev/null | \
        grep -i "InkOS\|Dashboard" | \
        tail -500 > "$RESULT_DIR/device_logs.txt" &

    local log_pid=$!
    sleep 3
    kill $log_pid 2>/dev/null || true

    if [ -s "$RESULT_DIR/device_logs.txt" ]; then
        log_info "Device logs saved to: $RESULT_DIR/device_logs.txt"
    else
        log_warn "No device logs captured"
    fi
}

# Fetch FileLogger output from device.
fetch_file_logs() {
    log_info "Fetching FileLogger output..."

    # Get app container path and fetch log file.
    local container_path=$(xcrun devicectl device info appContainer \
        --device "$IPAD_UDID" \
        --bundle-id "$BUNDLE_ID" \
        --container-type data 2>/dev/null | grep -o '/.*' || true)

    if [ -n "$container_path" ]; then
        log_info "App container: $container_path"
        # Note: Direct file access requires additional tooling.
        # For now, the app will write logs that XCUITest can retrieve.
    fi
}

# Print summary.
print_summary() {
    echo ""
    echo "======================================"
    echo "TEST RESULTS SUMMARY"
    echo "======================================"
    echo "Results directory: $RESULT_DIR"
    echo ""
    echo "Files:"
    ls -la "$RESULT_DIR/" 2>/dev/null || true
    echo ""

    # Show any captured screenshots.
    local screenshots=$(find "$RESULT_DIR" -name "*.png" 2>/dev/null | wc -l | tr -d ' ')
    echo "Screenshots captured: $screenshots"

    # Show test output summary.
    if [ -f "$RESULT_DIR/test_output.log" ]; then
        echo ""
        echo "Test output tail:"
        tail -20 "$RESULT_DIR/test_output.log"
    fi
}

# Main entry point.
main() {
    local test_filter="${1:-}"

    echo "======================================"
    echo "InkOS UI Test Runner"
    echo "======================================"
    echo "Device: $IPAD_NAME"
    echo "Time: $(date)"
    echo ""

    acquire_lock
    setup_output_dir

    if check_device; then
        run_tests "platform=iOS,name=$IPAD_NAME" "$test_filter"
    else
        log_error "No device connected. Connect iPad and try again."
        exit 1
    fi

    extract_screenshots
    fetch_device_logs
    print_summary
}

main "$@"
