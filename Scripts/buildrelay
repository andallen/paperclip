#!/bin/bash
set -euo pipefail

# Build the InkOSRelay Mac companion app.
cd "$(dirname "$0")/.."

echo "Building InkOSRelay..."

OUTPUT_DIR="./build"
mkdir -p "$OUTPUT_DIR"

swiftc \
  -o "$OUTPUT_DIR/InkOSRelay" \
  -target arm64-apple-macosx14.0 \
  -framework AppKit \
  -framework ImageIO \
  -framework UniformTypeIdentifiers \
  InkOSRelay/main.swift \
  InkOSRelay/AppDelegate.swift \
  InkOSRelay/ClipboardMonitor.swift \
  InkOSRelay/PNGMetadata.swift

echo "Built: $OUTPUT_DIR/InkOSRelay"
echo "Run with: $OUTPUT_DIR/InkOSRelay"
